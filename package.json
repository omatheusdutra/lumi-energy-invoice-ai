{
  "name": "teste-lumi-api",
  "version": "1.0.0",
  "description": "API RESTful para processamento de faturas de energia via LLM multimodal",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.19.0 <21 || >=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json --incremental false",
    "start": "npm run start:prod",
    "start:dev": "cross-env NODE_ENV=development LOG_FORMAT=pretty nest start --watch",
    "start:prod": "cross-env LOG_FORMAT=json node dist/src/main.js",
    "dev": "npm run start:dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "quality:check": "npm run format:check && npm run lint",
    "typecheck": "tsc --noEmit",
    "test": "cross-env NODE_ENV=test TEST_LOGGING_ENABLED=false jest --config ./jest.config.json",
    "test:watch": "cross-env NODE_ENV=test TEST_LOGGING_ENABLED=false jest --watch",
    "test:cov": "cross-env NODE_ENV=test TEST_LOGGING_ENABLED=false jest --coverage",
    "test:cov:full": "cross-env NODE_ENV=test TEST_LOGGING_ENABLED=false jest --config ./jest.coverage-full.config.cjs --coverage",
    "test:integration": "cross-env NODE_ENV=test TEST_LOGGING_ENABLED=false jest --config ./test/jest-integration.json",
    "test:e2e": "cross-env NODE_ENV=test TEST_LOGGING_ENABLED=false jest --config ./test/jest-e2e.json",
    "submission:check": "npm run quality:check && npm run test -- --runInBand && npm run test:integration -- --runInBand && npm run test:e2e -- --runInBand && npm run build",
    "prisma:generate": "prisma generate",
    "prisma:generate:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prisma-generate-safe.ps1",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:safe": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/prisma-migrate-deploy-safe.ps1",
    "prisma:seed": "ts-node prisma/seed.ts",
    "retention:purge": "node ./scripts/purge-llm-audit.mjs",
    "clean": "node ./scripts/clean.mjs",
    "clean:all": "node ./scripts/clean.mjs --all",
    "reset:deps": "npm run clean:all && npm ci",
    "loadtest:k6": "node ./scripts/loadtest/run-k6.mjs",
    "loadtest:autocannon": "node ./scripts/loadtest/run-autocannon.mjs",
    "slo:check": "node ./scripts/ops/check-stage-slo.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "helmet": "^8.1.0",
    "multer": "^2.0.2",
    "nestjs-pino": "^4.4.0",
    "openai": "^6.0.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.3",
    "cross-env": "^7.0.3",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.5.3",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.26.1"
  }
}
