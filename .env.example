NODE_ENV=development
APP_NAME=teste-lumi-api
PORT=3000
LOG_LEVEL=info
LOG_FORMAT=pretty
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lumi?schema=public
OPENAI_API_KEY=<SECRET>
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.5-flash
OPENAI_TIMEOUT_MS=20000
OPENAI_MAX_RETRIES=2
LLM_CIRCUIT_BREAKER_ENABLED=true
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
LLM_CIRCUIT_BREAKER_COOLDOWN_MS=30000
UPLOAD_MAX_MB=10
JSON_BODY_LIMIT_MB=1
URLENCODED_BODY_LIMIT_MB=1
CORS_ORIGIN=*
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=30
TRUST_PROXY=false
HEALTHCHECK_TIMEOUT_MS=2000
MAX_PAGE_SIZE=100
PRISMA_GENERATE_MAX_ATTEMPTS=5
PRISMA_GENERATE_BASE_DELAY_MS=750
PRISMA_MIGRATE_MAX_ATTEMPTS=5
PRISMA_MIGRATE_BASE_DELAY_MS=1000
FEATURE_DATA_QUALITY_ENABLED=true
FEATURE_ALERTS_ENABLED=true
FEATURE_TARIFF_READINESS_ENABLED=true
FEATURE_BENCHMARK_ENABLED=true
ALERT_SPIKE_PERCENT_THRESHOLD=30
ALERT_ZSCORE_THRESHOLD=2
ALERT_BASELINE_MIN_MONTHS=3
KPI_TOP_N_DEFAULT=5
RAW_LLM_AUDIT_TTL_DAYS=180
